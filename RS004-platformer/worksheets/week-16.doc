<p class="ruled">&nbsp;</p><p class="ruled">&nbsp;</p><p class="ruled">&nbsp;</p><p class="ruled">&nbsp;</p><p class="ruled">&nbsp;</p>

<pre><code class="language-python">if current_state == &quot;title&quot;:
    if event.key == pygame.K_SPACE:
        current_state = &quot;playing&quot;
    elif event.key == pygame.K_l:
        current_state = &quot;level_select&quot;
</code></pre>
